import customtkinter as ctk
from tkinter import ttk, messagebox
import sqlite3

ctk.set_appearance_mode("dark")
ctk.set_default_color_theme("blue")


class App(ctk.CTk):

    def __init__(gestor_de_estoque):
        super().__init__()

        gestor_de_estoque.title("Gestor de Estoque")
        gestor_de_estoque.geometry("900x600")

        gestor_de_estoque.usuario_id = None

        gestor_de_estoque.criar_banco()

        gestor_de_estoque.frame_atual = None

        gestor_de_estoque.tela_inicial()


    def criar_banco(gestor_de_estoque):

        gestor_de_estoque.conexao = sqlite3.connect("estoque.db")
        gestor_de_estoque.cursor = gestor_de_estoque.conexao.cursor()

        gestor_de_estoque.cursor.execute("""
        CREATE TABLE IF NOT EXISTS usuarios(
            id INTEGER PRIMARY KEY AUTOINCREMENT,
            nome TEXT UNIQUE,
            senha TEXT
        )
        """)

        gestor_de_estoque.cursor.execute("""
        CREATE TABLE IF NOT EXISTS itens(
            id INTEGER PRIMARY KEY AUTOINCREMENT,
            nome TEXT,
            quantidade INTEGER,
            usuario_id INTEGER NULL 
        )
        """)

        gestor_de_estoque.conexao.commit()


    def limpar_tela(gestor_de_estoque):

        if gestor_de_estoque.frame_atual:
            gestor_de_estoque.frame_atual.destroy()


    def tela_inicial(gestor_de_estoque):

        gestor_de_estoque.limpar_tela()

        gestor_de_estoque.frame_atual = ctk.CTkFrame(gestor_de_estoque)
        gestor_de_estoque.frame_atual.pack(fill="both", expand=True)

        titulo = ctk.CTkLabel(
            gestor_de_estoque.frame_atual,
            text="GESTOR DE ESTOQUE",
            font=("Arial", 30, "bold")
        )
        titulo.pack(pady=50)

        btn_login = ctk.CTkButton(
            gestor_de_estoque.frame_atual,
            text="Fazer Login",
            width=250,
            command=gestor_de_estoque.tela_login
        )
        btn_login.pack(pady=20)

        btn_cadastro = ctk.CTkButton(
            gestor_de_estoque.frame_atual,
            text="Cadastrar Usuário",
            width=250,
            command=gestor_de_estoque.tela_cadastro
        )
        btn_cadastro.pack(pady=20)

    def tela_cadastro(gestor_de_estoque):

        gestor_de_estoque.limpar_tela()

        gestor_de_estoque.frame_atual = ctk.CTkFrame(gestor_de_estoque)
        gestor_de_estoque.frame_atual.pack(fill="both", expand=True)

        ctk.CTkLabel(
            gestor_de_estoque.frame_atual,
            text="CADASTRAR USUÁRIO",
            font=("Arial", 25, "bold")
        ).pack(pady=30)

        gestor_de_estoque.nome_cadastro = ctk.CTkEntry(
            gestor_de_estoque.frame_atual,
            width=300,
            placeholder_text="Usuário"
        )
        gestor_de_estoque.nome_cadastro.pack(pady=20)

        gestor_de_estoque.senha_cadastro = ctk.CTkEntry(
            gestor_de_estoque.frame_atual,
            width=300,
            placeholder_text="Senha",
            show="*"
        )
        gestor_de_estoque.senha_cadastro.pack(pady=20)

        ctk.CTkButton(
            gestor_de_estoque.frame_atual,
            text="Cadastrar",
            command=gestor_de_estoque.cadastrar_usuario
        ).pack(pady=20)

        ctk.CTkButton(
            gestor_de_estoque.frame_atual,
            text="Voltar",
            command=gestor_de_estoque.tela_inicial
        ).pack(pady=20)


    def cadastrar_usuario(gestor_de_estoque):

        nome = gestor_de_estoque.nome_cadastro.get()
        senha = gestor_de_estoque.senha_cadastro.get()

        if not nome or not senha:
            messagebox.showwarning(
                "Atenção",
                "Preencha todos os campos."
            )
            return

        try:

            gestor_de_estoque.cursor.execute(
                "INSERT INTO usuarios(nome, senha) VALUES(?, ?)",
                (nome, senha)
            )

            gestor_de_estoque.conexao.commit()

            messagebox.showinfo(
                "Sucesso",
                "Usuário cadastrado!"
            )

            gestor_de_estoque.tela_login()

        except sqlite3.IntegrityError:

            messagebox.showerror(
                "Erro",
                "Usuário já existe."
            )

    def tela_login(gestor_de_estoque):

        gestor_de_estoque.limpar_tela()

        gestor_de_estoque.frame_atual = ctk.CTkFrame(gestor_de_estoque)
        gestor_de_estoque.frame_atual.pack(fill="both", expand=True)

        ctk.CTkLabel(
            gestor_de_estoque.frame_atual,
            text="LOGIN",
            font=("Arial", 25, "bold")
        ).pack(pady=30)

        gestor_de_estoque.nome_login = ctk.CTkEntry(
            gestor_de_estoque.frame_atual,
            width=300,
            placeholder_text="Usuário"
        )
        gestor_de_estoque.nome_login.pack(pady=20)

        gestor_de_estoque.senha_login = ctk.CTkEntry(
            gestor_de_estoque.frame_atual,
            width=300,
            placeholder_text="Senha",
            show="*"
        )
        gestor_de_estoque.senha_login.pack(pady=20)

        ctk.CTkButton(
            gestor_de_estoque.frame_atual,
            text="Entrar",
            command=gestor_de_estoque.fazer_login
        ).pack(pady=20)

        ctk.CTkButton(
            gestor_de_estoque.frame_atual,
            text="Voltar",
            command=gestor_de_estoque.tela_inicial
        ).pack(pady=20)

    def fazer_login(gestor_de_estoque):

        nome = gestor_de_estoque.nome_login.get()
        senha = gestor_de_estoque.senha_login.get()

        gestor_de_estoque.cursor.execute(
            "SELECT id FROM usuarios WHERE nome=? AND senha=?",
            (nome, senha)
        )

        usuario = gestor_de_estoque.cursor.fetchone()

        if usuario:

            gestor_de_estoque.usuario_id = usuario[0]

            

            gestor_de_estoque.tela_estoque()

        else:

            messagebox.showerror(
                "Erro",
                "Usuário ou senha incorretos."
            )

    def tela_estoque(gestor_de_estoque):

        gestor_de_estoque.limpar_tela()

        gestor_de_estoque.frame_atual = ctk.CTkFrame(gestor_de_estoque)
        gestor_de_estoque.frame_atual.pack(fill="both", expand=True)

        titulo = ctk.CTkLabel(
            gestor_de_estoque.frame_atual,
            text="CONTROLE DE ESTOQUE",
            font=("Arial", 25, "bold")
        )
        titulo.pack(pady=20)

        frame_topo = ctk.CTkFrame(gestor_de_estoque.frame_atual)
        frame_topo.pack(fill="x", padx=20, pady=20)

        gestor_de_estoque.entry_produto = ctk.CTkEntry(
            frame_topo,
            placeholder_text="Nome do Produto"
        )
        gestor_de_estoque.entry_produto.grid(
            row=0,
            column=0,
            padx=20,
            pady=20
        )

        gestor_de_estoque.entry_quantidade = ctk.CTkEntry(
            frame_topo,
            placeholder_text="Quantidade"
        )
        gestor_de_estoque.entry_quantidade.grid(
            row=0,
            column=1,
            padx=20,
            pady=20
        )

        ctk.CTkButton(
            frame_topo,
            text="Adicionar Produto",
            command=gestor_de_estoque.adicionar_produto
        ).grid(
            row=0,
            column=2,
            padx=20
        )

        frame_tabela = ctk.CTkFrame(gestor_de_estoque.frame_atual)
        frame_tabela.pack(
            fill="both",
            expand=True,
            padx=20,
            pady=20
        )
        
        style = ttk.Style()
        style.configure("Treeview",font = ("Arial", 12,"bold"))
        
        gestor_de_estoque.tabela = ttk.Treeview(
            frame_tabela,
            columns=("ID", "Nome", "Quantidade"),
            show="headings"
        )

        gestor_de_estoque.tabela.heading("ID", text="ID")
        gestor_de_estoque.tabela.heading("Nome", text="Produto")
        gestor_de_estoque.tabela.heading("Quantidade", text="Quantidade")

        gestor_de_estoque.tabela.column("ID", width=80)
        gestor_de_estoque.tabela.column("Nome", width=300)
        gestor_de_estoque.tabela.column("Quantidade", width=150)

        gestor_de_estoque.tabela.pack(
            fill="both",
            expand=True
        )

        frame_botoes = ctk.CTkFrame(gestor_de_estoque.frame_atual)
        frame_botoes.pack(fill="x", padx=20, pady=20)

        ctk.CTkButton(
            frame_botoes,
            text="Retirar Quantidade",
            command=gestor_de_estoque.retirar_quantidade
        ).pack(side="left", padx=5)

        ctk.CTkButton(
            frame_botoes,
            text="Remover Produto",
            command=gestor_de_estoque.remover_produto
        ).pack(side="left", padx=5)

        ctk.CTkButton(
            frame_botoes,
            text="Excluir Conta",
            fg_color="red",
            command=gestor_de_estoque.excluir_conta
        ).pack(side="left", padx=5)

        ctk.CTkButton(
            frame_botoes,
            text="Registrar Venda",
            fg_color="green",
            command=gestor_de_estoque.registrar_venda   
        ).pack(side="left", padx=5)

        ctk.CTkButton(
            frame_botoes,
            text="Logout",
            command=gestor_de_estoque.logout
        ).pack(side="top", padx=5, pady=5)

        gestor_de_estoque.carregar_itens()


    def carregar_itens(gestor_de_estoque):

        for item in gestor_de_estoque.tabela.get_children():
            gestor_de_estoque.tabela.delete(item)

        gestor_de_estoque.cursor.execute(
            """
            SELECT id,nome,quantidade
            FROM itens
            """
        )

        itens = gestor_de_estoque.cursor.fetchall()

        for item in itens:

            gestor_de_estoque.tabela.insert(
                "",
                "end",
                values=item
            )


    def adicionar_produto(gestor_de_estoque):

        nome = gestor_de_estoque.entry_produto.get()

        try:
            quantidade = int(
                gestor_de_estoque.entry_quantidade.get()
            )
        except:
            messagebox.showerror(
                "Erro",
                "Quantidade inválida."
            )
            return

        if not nome:

            messagebox.showerror(
                "Erro",
                "Digite o nome do produto."
            )
            return

        gestor_de_estoque.cursor.execute(
            """
            INSERT INTO itens
            (nome, quantidade, usuario_id)
            VALUES (?, ?, ?)
            """,
            (
                nome,
                quantidade,
                gestor_de_estoque.usuario_id
            )
        )

        gestor_de_estoque.conexao.commit()

        gestor_de_estoque.entry_produto.delete(0, "end")
        gestor_de_estoque.entry_quantidade.delete(0, "end")

        gestor_de_estoque.carregar_itens()

    def retirar_quantidade(gestor_de_estoque):

        selecionado = gestor_de_estoque.tabela.selection()

        if not selecionado:

            messagebox.showwarning(
                "Atenção",
                "Selecione um produto."
            )
            return

        dados = gestor_de_estoque.tabela.item(
            selecionado
        )["values"]

        id_item = dados[0]

        janela = ctk.CTkInputDialog(
            text="Quantidade a retirar:",
            title="Retirada"
        )

        valor = janela.get_input()

        if not valor:
            return

        try:
            retirada = int(valor)
        except:
            return

        gestor_de_estoque.cursor.execute(
            """
            SELECT quantidade
            FROM itens
            WHERE id=?
            """,
            (id_item,)
        )

        quantidade = gestor_de_estoque.cursor.fetchone()[0]

        if retirada > quantidade:

            messagebox.showerror(
                "Erro",
                "Estoque insuficiente."
            )
            return

        nova = quantidade - retirada

        gestor_de_estoque.cursor.execute(
            """
            UPDATE itens
            SET quantidade=?
            WHERE id=?
            """,
            (nova, id_item)
        )

        gestor_de_estoque.conexao.commit()

        if nova <= 5:

            messagebox.showwarning(
                "Estoque Baixo",
                "Produto com estoque baixo."
            )

        gestor_de_estoque.carregar_itens()

    def remover_produto(gestor_de_estoque):

        selecionado = gestor_de_estoque.tabela.selection()

        if not selecionado:

            messagebox.showwarning(
                "Atenção",
                "Selecione um produto."
            )
            return

        resposta = messagebox.askyesno(
            "Confirmação",
            "Deseja remover o produto?"
        )

        if not resposta:
            return

        dados = gestor_de_estoque.tabela.item(
            selecionado
        )["values"]

        id_item = dados[0]

        gestor_de_estoque.cursor.execute(
            """
            DELETE FROM itens
            WHERE id=?
            """,
            (id_item,)
        )

        gestor_de_estoque.conexao.commit()

        gestor_de_estoque.carregar_itens()

    def registrar_venda(gestor_de_estoque):

        selecionado = gestor_de_estoque.tabela.selection()

        if not selecionado:

            messagebox.showwarning(
                "Atenção",
                "Selecione um produto."
            )
            return

        dados = gestor_de_estoque.tabela.item(
            selecionado
        )["values"]

        id_item = dados[0]
        nome_produto = dados[1]

        janela = ctk.CTkInputDialog(
            text="Quantidade vendida:",
            title="Registrar Venda"
        )

        valor = janela.get_input()

        if not valor:
            return

        try:
            quantidade_vendida = int(valor)
        except:
            return

        gestor_de_estoque.cursor.execute(
            """
            SELECT quantidade
            FROM itens
            WHERE id=?
            """,
            (id_item,)
        )

        quantidade_estoque = gestor_de_estoque.cursor.fetchone()[0]

        if quantidade_vendida > quantidade_estoque:

            messagebox.showerror(
                "Erro",
                "Estoque insuficiente para essa venda."
            )
            return

        nova_quantidade = quantidade_estoque - quantidade_vendida

        gestor_de_estoque.cursor.execute(
            """
            UPDATE itens
            SET quantidade=?
            WHERE id=?
            """,
            (nova_quantidade, id_item)
        )

        gestor_de_estoque.conexao.commit()

        messagebox.showinfo(
            "Venda Registrada",
            f"Venda de {quantidade_vendida} unidades de '{nome_produto}' registrada com sucesso!"
        )

        if nova_quantidade <= 5:

            messagebox.showwarning(
                "Estoque Baixo",
                "Produto com estoque baixo."
            )

        gestor_de_estoque.carregar_itens()
    

    def excluir_conta(gestor_de_estoque):

        resposta = messagebox.askyesno(
            "Excluir Conta",
            "Todos os itens serão apagados.\nDeseja continuar?"
        )

        if not resposta:
            return

        gestor_de_estoque.cursor.execute(
            """
            DELETE FROM itens
            WHERE usuario_id=?
            """,
            (gestor_de_estoque.usuario_id,)
        )

        gestor_de_estoque.cursor.execute(
            """
            DELETE FROM usuarios
            WHERE id=?
            """,
            (gestor_de_estoque.usuario_id,)
        )

        gestor_de_estoque.conexao.commit()

        messagebox.showinfo(
            "Sucesso",
            "Conta excluída."
        )

        gestor_de_estoque.usuario_id = None

        gestor_de_estoque.tela_inicial()

    def logout(gestor_de_estoque):

        gestor_de_estoque.usuario_id = None

        gestor_de_estoque.tela_inicial()

    
    def destroy(gestor_de_estoque):

        gestor_de_estoque.conexao.close()

        super().destroy()


app = App()
app.mainloop()